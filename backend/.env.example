# ── FlashSol v6 — Environment Variables ──────────────────────────────────────

# Solana
SOLANA_NETWORK=devnet
RPC_URL=https://api.devnet.solana.com
PROJECT_WALLET=<ваш Solana-кошелёк для получения выплат>

# PostgreSQL (Railway: автоматически заполняется при добавлении Postgres сервиса)
DATABASE_URL=postgresql://user:password@localhost:5432/flashsol
DB_SSL=false  # true на Railway/production

# Security
ADMIN_SECRET=<генерировать: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))">

# CORS (обязателен в production)
FRONTEND_URL=http://localhost:5500  # production: https://ваш-домен.com

# Server
PORT=3001
NODE_ENV=development  # production на Railway
